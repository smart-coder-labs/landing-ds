# Configuración de registro público npm
registry=https://registry.npmjs.org/
@smart-coder-labs:registry=https://registry.npmjs.org/

# Token de autenticación — usar variable de entorno o npm login
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}

# Configuración de pnpm
auto-install-peers=true
strict-peer-dependencies=false
node-linker=hoisted